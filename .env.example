# Copy to .env for local development. Do not commit real values.

# Google / Gemini / Vertex AI
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_API_KEY=
VERTEX_AI_SEARCH_DATASTORE=

# MCP server configuration
SHIPWRIGHT_MCP_JIRA_URL=https://mcp.atlassian.com/v1/mcp/authv2
SHIPWRIGHT_MCP_LINEAR_URL=https://mcp.linear.app/mcp
SHIPWRIGHT_MCP_SLACK_URL=https://mcp.slack.com/mcp
SHIPWRIGHT_MCP_GITHUB_URL=
SHIPWRIGHT_MCP_JIRA_TOKEN=
SHIPWRIGHT_MCP_LINEAR_TOKEN=
SHIPWRIGHT_MCP_SLACK_TOKEN=
SHIPWRIGHT_MCP_GITHUB_TOKEN=
SHIPWRIGHT_DEMO_JIRA_ISSUE_KEY=SHIP-100
SHIPWRIGHT_DEMO_SLACK_CHANNEL=#shipwright-demo
SHIPWRIGHT_DEMO_GITHUB_REPO=Valentyx/shipwright-ai-agent-challenge

# Live integration credentials belong in local env vars or Secret Manager.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
LINEAR_API_KEY=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_MCP_APP_ID=
SLACK_MCP_CLIENT_ID=
SLACK_MCP_CLIENT_SECRET=
SLACK_MCP_USER_TOKEN=
GITHUB_TOKEN=

# Runtime
PORT=8080
SHIPWRIGHT_QUIET_LOGS=0
