# Copy to .env for local development. Do not commit real values.

# Google / Gemini / Vertex AI
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_API_KEY=
VERTEX_AI_SEARCH_DATASTORE=
SHIPWRIGHT_REASONING_PROVIDER=deterministic
SHIPWRIGHT_REASONING_MODEL=gemini-2.5-flash

# MCP server configuration
SHIPWRIGHT_MCP_JIRA_URL=http://localhost:9001
SHIPWRIGHT_MCP_SLACK_URL=http://localhost:9002
SHIPWRIGHT_MCP_GITHUB_URL=http://localhost:9003

# Live integration credentials belong in local env vars or Secret Manager.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
GITHUB_TOKEN=

# Runtime
PORT=8080
SHIPWRIGHT_QUIET_LOGS=0
